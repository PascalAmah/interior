<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ site.tagline }}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400;1,9..144,500&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <style>
      :root {
        --ink: #1b1814;
        --linen: #faf6ef;
        --linen-deep: #f3ecdf;
        --terracotta: #c76b3f;
        --terracotta-deep: #a6532e;
        --moss: #3d4a3d;
        --moss-deep: #2b352b;
        --stone: #e8dfd0;
        --caption: #8a8175;
        --line: rgba(27, 24, 20, 0.12);
        --line-strong: rgba(27, 24, 20, 0.22);
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body { background: var(--linen); color: var(--ink); font-family: "Inter", sans-serif; font-size: 16px; line-height: 1.6; -webkit-font-smoothing: antialiased; }
      h1, h2, h3, .display { font-family: "Fraunces", serif; font-weight: 500; letter-spacing: -0.01em; line-height: 1.05; }
      a { color: inherit; text-decoration: none; }
      img { display: block; max-width: 100%; }
      .wrap { max-width: 1180px; margin: 0 auto; padding: 30px 40px; }
      @media (max-width: 880px) { .wrap { padding: 30px 24px; } }
      input, textarea, select { font-size: 16px !important; }
      .eyebrow { display: flex; align-items: center; gap: 10px; font-size: 12.5px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--caption); font-weight: 500; margin-bottom: 18px; }
      .eyebrow::before { content: ""; width: 18px; height: 1px; background: var(--terracotta); display: inline-block; }
      @media (max-width: 880px) { .wrap { padding: 24px 20px; } }
    </style>
    <link rel="stylesheet" href="/css/main.css" />
  </head>
  <body>
    <header>
      <nav>
        <a href="#" class="logo"><span class="logo-mark"></span>{{ site.name }}</a>
        <div class="nav-links">
          <a href="#philosophy">Studio</a>
          <a href="#services">Services</a>
          <a href="#work">Work</a>
          <a href="#process">Process</a>
          <a href="#contact">Contact</a>
        </div>
        <a href="#contact" class="nav-cta">Book a consultation</a>
      </nav>
    </header>

    {{ content | safe }}

    <footer>
      <div class="wrap">
        <div class="footer-top">
          <div class="footer-brand">
            <a href="#" class="logo"><span class="logo-mark"></span>{{ site.name }}</a>
            <p>Designing spaces that hold weight — for the life that happens inside them.</p>
            <div class="footer-socials">
              <a href="#" aria-label="LinkedIn">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </a>
              <a href="#" aria-label="Instagram">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
                </svg>
              </a>
              <a href="#" aria-label="Behance">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M22 7h-7V5h7v2zm1.726 10c-.442 1.297-2.029 3-5.101 3-3.074 0-5.564-1.729-5.564-5.675 0-3.91 2.325-5.92 5.466-5.92 3.082 0 4.964 1.782 5.375 4.426.078.506.109 1.188.095 2.14H15.97c.13 3.211 3.483 3.312 4.588 2.029H23.726zm-7.686-3h4.965c-.105-1.547-1.136-2.219-2.477-2.219-1.466 0-2.277.768-2.488 2.219zm-9.574 6.988H0V5.021h6.953c5.476.081 5.58 5.444 2.72 6.906 3.461 1.26 3.577 8.061-3.207 8.061zM3 11h3.584c2.508 0 2.906-3-.312-3H3v3zm3.391 3H3v3.016h3.341c3.055 0 2.868-3.016.05-3.016z"/>
                </svg>
              </a>
            </div>
          </div>
          <div class="footer-col">
            <h4>Studio</h4>
            <a href="#philosophy">Who we are</a>
            <a href="#services">Services</a>
            <a href="#process">Process</a>
          </div>
          <div class="footer-col">
            <h4>Work</h4>
            <a href="#work">Portfolio</a>
            <a href="#contact">Start a project</a>
          </div>
          <div class="footer-col">
            <h4>Contact</h4>
            <a href="tel:{{ site.phoneRaw }}">{{ site.phone }}</a>
            <a href="#contact">Send a message</a>
          </div>
        </div>
        <div class="footer-bottom">
          <span>&copy; 2025 {{ site.name }} Interiors. All rights reserved.</span>
          <span>Crafted with care.</span>
        </div>
      </div>
    </footer>

    <script>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", user => {
          if (!user) {
            window.netlifyIdentity.on("login", () => {
              document.location.href = "/admin/";
            });
          }
        });
      }
      const reveals = document.querySelectorAll(".reveal");
      const io = new IntersectionObserver(entries => {
        entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add("in"); io.unobserve(e.target); } });
      }, { threshold: 0.12 });
      reveals.forEach(el => io.observe(el));

      // Testimonial slider
      const cards = document.querySelectorAll(".testimonial-card");
      if (cards.length > 1) {
        let current = 0;
        let timer;

        function goTo(idx) {
          cards.forEach((c, i) => {
            c.classList.toggle("active", i === idx);
            c.querySelectorAll(".test-dots span").forEach((d, di) => {
              d.classList.toggle("active", di === idx);
            });
          });
          current = idx;
        }

        function next() {
          goTo((current + 1) % cards.length);
        }

        function startAuto() {
          timer = setInterval(next, 3000);
        }

        function stopAuto() {
          clearInterval(timer);
        }

        // Dot click — manual override, resets auto timer
        document.querySelectorAll(".test-dots").forEach(dotsEl => {
          dotsEl.querySelectorAll("span").forEach(dot => {
            dot.addEventListener("click", () => {
              stopAuto();
              goTo(parseInt(dot.dataset.dot));
              startAuto();
            });
          });
        });

        // Pause on hover
        const wrapper = document.querySelector(".testimonial-wrapper");
        if (wrapper) {
          wrapper.addEventListener("mouseenter", stopAuto);
          wrapper.addEventListener("mouseleave", startAuto);
        }

        startAuto();
      }
    </script>
  </body>
</html>
