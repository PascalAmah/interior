<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ site.tagline }}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400;1,9..144,500&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <style>
      :root {
        --ink: #1b1814;
        --linen: #faf6ef;
        --linen-deep: #f3ecdf;
        --terracotta: #c76b3f;
        --terracotta-deep: #a6532e;
        --moss: #3d4a3d;
        --moss-deep: #2b352b;
        --stone: #e8dfd0;
        --caption: #8a8175;
        --line: rgba(27, 24, 20, 0.12);
        --line-strong: rgba(27, 24, 20, 0.22);
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body { background: var(--linen); color: var(--ink); font-family: "Inter", sans-serif; font-size: 16px; line-height: 1.6; -webkit-font-smoothing: antialiased; }
      h1, h2, h3, .display { font-family: "Fraunces", serif; font-weight: 500; letter-spacing: -0.01em; line-height: 1.05; }
      a { color: inherit; text-decoration: none; }
      img { display: block; max-width: 100%; }
      .wrap { max-width: 1180px; margin: 0 auto; padding: 30px 40px; }
      .eyebrow { display: flex; align-items: center; gap: 10px; font-size: 12.5px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--caption); font-weight: 500; margin-bottom: 18px; }
      .eyebrow::before { content: ""; width: 18px; height: 1px; background: var(--terracotta); display: inline-block; }
      @media (max-width: 880px) { .wrap { padding: 24px 20px; } }
    </style>
    <link rel="stylesheet" href="/css/main.css" />
  </head>
  <body>
    <header>
      <nav>
        <a href="#" class="logo"><span class="logo-mark"></span>{{ site.name }}</a>
        <div class="nav-links">
          <a href="#philosophy">Studio</a>
          <a href="#services">Services</a>
          <a href="#work">Work</a>
          <a href="#process">Process</a>
          <a href="#contact">Contact</a>
        </div>
        <a href="#contact" class="nav-cta">Book a consultation</a>
      </nav>
    </header>

    {{ content | safe }}

    <footer>
      <div class="wrap">
        <div class="footer-top">
          <div class="footer-brand">
            <a href="#" class="logo"><span class="logo-mark"></span>{{ site.name }}</a>
            <p>Designing spaces that hold weight — for the life that happens inside them.</p>
            <div class="footer-socials">
              <a href="#">in</a>
              <a href="#">ig</a>
              <a href="#">be</a>
            </div>
          </div>
          <div class="footer-col">
            <h4>Studio</h4>
            <a href="#philosophy">Who we are</a>
            <a href="#services">Services</a>
            <a href="#process">Process</a>
          </div>
          <div class="footer-col">
            <h4>Work</h4>
            <a href="#work">Portfolio</a>
            <a href="#contact">Start a project</a>
          </div>
          <div class="footer-col">
            <h4>Contact</h4>
            <a href="tel:{{ site.phoneRaw }}">{{ site.phone }}</a>
            <a href="#contact">Send a message</a>
          </div>
        </div>
        <div class="footer-bottom">
          <span>&copy; 2025 {{ site.name }} Interiors. All rights reserved.</span>
          <span>Crafted with care.</span>
        </div>
      </div>
    </footer>

    <script>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", user => {
          if (!user) {
            window.netlifyIdentity.on("login", () => {
              document.location.href = "/admin/";
            });
          }
        });
      }
      const reveals = document.querySelectorAll(".reveal");
      const io = new IntersectionObserver(entries => {
        entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add("in"); io.unobserve(e.target); } });
      }, { threshold: 0.12 });
      reveals.forEach(el => io.observe(el));

      // Testimonial slider
      const cards = document.querySelectorAll(".testimonial-card");
      if (cards.length > 1) {
        let current = 0;
        let timer;

        function goTo(idx) {
          cards.forEach((c, i) => {
            c.classList.toggle("active", i === idx);
            c.querySelectorAll(".test-dots span").forEach((d, di) => {
              d.classList.toggle("active", di === idx);
            });
          });
          current = idx;
        }

        function next() {
          goTo((current + 1) % cards.length);
        }

        function startAuto() {
          timer = setInterval(next, 3000);
        }

        function stopAuto() {
          clearInterval(timer);
        }

        // Dot click — manual override, resets auto timer
        document.querySelectorAll(".test-dots").forEach(dotsEl => {
          dotsEl.querySelectorAll("span").forEach(dot => {
            dot.addEventListener("click", () => {
              stopAuto();
              goTo(parseInt(dot.dataset.dot));
              startAuto();
            });
          });
        });

        // Pause on hover
        const wrapper = document.querySelector(".testimonial-wrapper");
        if (wrapper) {
          wrapper.addEventListener("mouseenter", stopAuto);
          wrapper.addEventListener("mouseleave", startAuto);
        }

        startAuto();
      }
    </script>
  </body>
</html>
